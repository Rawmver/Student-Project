# =============================================================================
# Student Group Dashboard — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values you need.
#
#   cp .env.example .env
#
# Only DATABASE_URL and SESSION_SECRET are required to boot. Everything else
# can be left blank here and pasted later from the admin Credentials panel
# (Admin → Credentials). Values pasted in the admin panel OVERRIDE the values
# in this file at runtime, with no restart needed.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. DATABASE_URL                                              [REQUIRED]
# -----------------------------------------------------------------------------
# Purpose : PostgreSQL connection string. The app stores everything here
#           (groups, students, submissions, sessions, settings, push subs,
#           calendar events, announcements).
# Where to get it:
#   - Local dev .... install Postgres, then `createdb student_dashboard`
#   - Neon ......... https://neon.tech (free 0.5 GB, never expires) — recommended
#   - Supabase ..... https://supabase.com (free 500 MB, pauses after 7 days idle)
#   - Render ....... add a Postgres database in the dashboard, copy the
#                    "Internal Database URL"
#   - Railway ...... add a Postgres plugin, copy DATABASE_URL from Variables
# Format  : postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Example : postgresql://postgres:postgres@localhost:5432/student_dashboard
# Example : postgresql://neondb_owner:abc123@ep-cool-pine.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/student_dashboard


# -----------------------------------------------------------------------------
# 2. SESSION_SECRET                                            [REQUIRED]
# -----------------------------------------------------------------------------
# Purpose : Long random string used to sign Express session cookies.
#           If this changes, every logged-in user is signed out.
# How to generate (run in your terminal):
#           node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Example : a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2
SESSION_SECRET=replace-me-with-a-long-random-string-min-32-chars


# -----------------------------------------------------------------------------
# 3. OPENAI_API_KEY                                            [optional]
# -----------------------------------------------------------------------------
# Purpose : Powers the AI Admin Assistant in the admin dashboard and the
#           "Explain this video" button in the student Virtual Room.
# Where to get it: https://platform.openai.com/api-keys
# Cost    : Pay-per-use (you pay OpenAI directly). GPT-4o ≈ $5 / 1M input tokens.
# Example : sk-proj-abc123XYZ456...
OPENAI_API_KEY=


# -----------------------------------------------------------------------------
# 4. YOUTUBE_API_KEY                                           [optional]
# -----------------------------------------------------------------------------
# Purpose : Used by the Virtual Room video search (student portal).
#           When unset, the app falls back to scraping youtube.com which
#           is fragile and breaks when YouTube changes its HTML.
# Where to get it:
#   1. https://console.cloud.google.com/apis/credentials
#   2. Create project → "Enable APIs" → enable "YouTube Data API v3"
#   3. Credentials → "Create credentials" → "API key"
# Cost    : Free, 10,000 units/day quota.
# Example : AIzaSyABC123def456GHI789jkl
YOUTUBE_API_KEY=


# -----------------------------------------------------------------------------
# 5. RESEND_API_KEY                                            [optional]
# -----------------------------------------------------------------------------
# Purpose : Sends transactional email — admin 2FA login codes, magic-link
#           password resets, student-account verification emails.
#           Without this, students CANNOT register and the admin cannot
#           recover the password.
# Where to get it: https://resend.com/api-keys (free 100 emails/day, 3000/month)
# Example : re_AbCdEfGh_1234567890abcdefghij
RESEND_API_KEY=

# Purpose : The "From" header on outgoing email.
# Constraint:
#   - On Resend's free tier this MUST be onboarding@resend.dev OR a verified
#     domain you own (https://resend.com/domains).
#   - Display name is optional but recommended.
# Example : Student Group Portal <onboarding@resend.dev>
# Example : Acme University <noreply@acme.edu>
RESEND_FROM=Student Group Portal <onboarding@resend.dev>


# -----------------------------------------------------------------------------
# 6. VIRUSTOTAL_API_KEY                                        [optional]
# -----------------------------------------------------------------------------
# Purpose : Adds a third layer of upload virus scanning (after blocked
#           extensions and magic-byte checks). Uses the v3 hash-lookup
#           endpoint (no file bytes are uploaded, only a SHA-256 hash).
#           If unset, only the local extension + magic-byte checks run.
# Where to get it: https://www.virustotal.com/gui/my-apikey (free, requires sign up)
# Quota   : Free tier = 4 lookups/min, 500/day, 15,500/month.
# Example : 5a3b7c9d1e2f4a6b8c0d2e4f6a8b0c2d4e6f8a0b2c4d6e8f0a2b4c6d8e0f1a2b
VIRUSTOTAL_API_KEY=


# -----------------------------------------------------------------------------
# 7. VAPID keys (Web Push)                                     [optional]
# -----------------------------------------------------------------------------
# Purpose : Browser push notifications for assignment / exam reminders
#           (1–2 days before due). Without these, push notifications are
#           silently disabled — the rest of the app keeps working.
# How to generate a fresh pair (run once, paste the output below):
#           npx web-push generate-vapid-keys
# WARNING : If you change these AFTER users have subscribed, all existing
#           subscriptions become invalid and users must re-subscribe.

# Public key — sent to the browser to identify your server.
# Example : BPx7r8...long-base64url-string...AaBb
VAPID_PUBLIC_KEY=

# Private key — kept on the server only. NEVER commit this to git.
# Example : k5JdQv...short-base64url-string...zZyY
VAPID_PRIVATE_KEY=

# Contact email or URL for the push service. Required by VAPID spec so
# push providers (Apple/Google/Mozilla) can reach you about abuse.
# Example : mailto:admin@youruniversity.edu
VAPID_SUBJECT=mailto:admin@example.com


# -----------------------------------------------------------------------------
# 8. GOOGLE_BOOKS_API_KEY                                      [optional]
# -----------------------------------------------------------------------------
# Purpose : Powers the student portal's Library tab — book search by title,
#           author, publisher, year, ISBN; finds free public-domain PDFs.
#           Without a key, the public quota of ~1,000 requests/day is used
#           (often runs out fast with active students).
# Where to get it:
#   1. https://console.cloud.google.com/apis/credentials
#   2. Create / pick a project → "Enable APIs" → enable "Books API"
#   3. Credentials → "+ Create credentials" → "API key"
# Quota   : Free, 100,000 queries/day with a key.
# Example : AIzaSyXYZ987abc654DEF321ghi
GOOGLE_BOOKS_API_KEY=


# -----------------------------------------------------------------------------
# 9. APP_BASE_URL                                              [optional]
# -----------------------------------------------------------------------------
# Purpose : Force the URL used in emailed links (magic links, OTPs).
#           Leave empty to auto-detect from REPLIT_DEPLOYMENT_DOMAIN /
#           REPLIT_DOMAINS / localhost. Set this manually when self-hosting.
# Example : https://groups.youruniversity.edu
# Example : http://localhost:5000
APP_BASE_URL=


# -----------------------------------------------------------------------------
# 10. Server runtime                                           [defaults shown]
# -----------------------------------------------------------------------------
# Port the Express server listens on. Both API and frontend are served here.
PORT=5000

# Set to "production" when running `npm run start`.
NODE_ENV=development


# =============================================================================
# 11. Replit-only variables — IGNORE these when running outside Replit.
# =============================================================================
# These are auto-injected by Replit. Do NOT set them by hand on other hosts.
# (Listed here only so you know what they're for if you see them in the wild.)
#
# REPL_ID                          — Replit OIDC client ID (used by /api/login).
# REPLIT_DOMAINS                   — comma-separated dev domains.
# REPLIT_DEPLOYMENT_DOMAIN         — production domain after deploy.
# ISSUER_URL                       — OIDC issuer (default https://replit.com/oidc).
# PRIVATE_OBJECT_DIR               — bucket path for private uploads.
#                                    Off-Replit: leave empty → falls back to ./uploads/
# PUBLIC_OBJECT_SEARCH_PATHS       — bucket paths for public assets.
# DEFAULT_OBJECT_STORAGE_BUCKET_ID — Replit Object Storage bucket id.
